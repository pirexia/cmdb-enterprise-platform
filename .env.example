# ══════════════════════════════════════════════════════════════════════════════
# CMDB Enterprise Platform — Environment Variables
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values
# 3. Run:              docker compose up -d --build
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=cmdb_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=cmdb_pass123          # Change in production!
POSTGRES_PORT=5432                      # Host port mapped to the DB container

# ─── Backend API ──────────────────────────────────────────────────────────────
BACKEND_PORT=3000                       # Host port mapped to the backend container

# JWT secret — use a long random string in production, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
FRONTEND_PORT=3001                      # Host port mapped to the frontend container

# URL of the backend API as seen from the USER'S BROWSER (not from inside Docker).
# In production, replace with your real domain or server IP:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# Note: this value is BAKED INTO the frontend image at build time.
#       Changing it after build requires a rebuild.
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Adminer (DB admin UI) ────────────────────────────────────────────────────
ADMINER_PORT=8080                       # Access at http://localhost:8080

# ─── Security / TLS (Misión 13) ───────────────────────────────────────────────
# Enable HTTPS on the backend (requires certs in backend/certs/).
# Generate certs: bash backend/scripts/generate-certs.sh
#                 (or: powershell -File backend\scripts\generate-certs.ps1)
HTTPS_ENABLED=false

# Allowed CORS origins (comma-separated). Backend rejects all other Origins.
# In production replace with your real domain(s).
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# When HTTPS_ENABLED=true, update NEXT_PUBLIC_API_URL to use https:
# NEXT_PUBLIC_API_URL=https://localhost:3000

# ─── Alert Engine / Email Notifications (Misión 14) ───────────────────────────
# SMTP server for outgoing alert emails.
# Gmail example (use an App Password, not your regular password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false       # true only for port 465
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # 16-char App Password
#
# Office 365 example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=your@company.com
#   SMTP_PASS=yourpassword
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Destination address for all alert reports
ALERT_RECIPIENT=admin@yourdomain.com

# Days ahead to start warning about expiring items (default: 30)
ALERT_WARN_DAYS=30

# Cron schedule for the daily alert job (default: 08:30 AM Europe/Madrid).
# Use "* * * * *" to trigger every minute for testing.
# Syntax: minute hour day month weekday
ALERT_CRON_SCHEDULE=30 8 * * *
