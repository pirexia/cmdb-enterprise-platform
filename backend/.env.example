# Copy this file to .env and fill in your values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
PORT=3000
JWT_SECRET="your-long-random-jwt-secret-here"

# ── LDAP / Active Directory (optional) ───────────────────────────────────────
# Set USE_LDAP=true to validate credentials against your corporate AD/LDAP.
# When false (default), the platform uses local bcrypt authentication.
USE_LDAP=false
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
# Set to 0 to accept self-signed / corporate CA certificates (LDAPS)
LDAP_TLS_REJECT_UNAUTHORIZED=0
