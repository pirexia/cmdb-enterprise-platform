# Dependencies
node_modules/

# Environment — never commit secrets
.env
.env.local
.env.*.local

# Build output
dist/
build/

# Prisma generated client (regenerated via `prisma generate`)
node_modules/.prisma/

# Logs
*.log
npm-debug.log*

# OS artifacts
.DS_Store
Thumbs.db

# TypeScript incremental compilation cache
*.tsbuildinfo

# SSL certificates — generated locally, never commit private keys
certs/*.key
certs/*.crt
certs/*.pem
certs/*.pfx
# (the .gitkeep inside certs/ is still tracked)
